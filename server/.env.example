# Copy to server/.env for local dev. On Railway, set these as service
# variables instead (never commit real values).

# Plaid — Sandbox keys from https://dashboard.plaid.com (Team settings -> Keys)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Optional: public URL Plaid should send transaction webhooks to,
# e.g. https://<railway-service>.up.railway.app/api/plaid/webhook
PLAID_WEBHOOK_URL=

# Clerk — secret key from https://dashboard.clerk.com (API keys)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=pk_test_Z29vZC1iZWRidWctNDguY2xlcmsuYWNjb3VudHMuZGV2JA

# Postgres — Railway injects this when the database is referenced as
# ${{Postgres.DATABASE_URL}}; local default below
DATABASE_URL=postgres://localhost:5432/alder

PORT=3001
